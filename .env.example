# Copy to server/.env or set in your process manager (do not commit real secrets).
#
# --- Vercel (frontend) ---
# Deploy API first (Render — see render.yaml), then on Vercel set:
# COMMAND_CENTRE_API_URL=https://your-render-service.onrender.com
# (No trailing slash. Redeploy after adding the variable.)

# --- Production auth (recommended) ---
FAMILY_OFFICE_AUTH=sqlite
FAMILY_OFFICE_SQLITE=server/data/family-office.sqlite
JWT_SECRET=change-me-to-a-long-random-string
FAMILY_OFFICE_MFA_KEY=change-me-another-long-random-string
# Lead/analyst must enroll MFA on first login (set to 0 to disable)
FAMILY_OFFICE_MFA_REQUIRED=1

# --- Email (communications follow-up, task alerts, import, digest) ---
SMTP_URL=smtps://user:password@smtp.example.com:465
SMTP_FROM=command-centre@yourdomain.com
SMTP_TO=lead@yourdomain.com
SMTP_DIGEST_TO=lead@yourdomain.com
# Map display names / roles to emails when app_users.email is empty
FAMILY_OFFICE_EMAIL_MAP={"Lead":"lead@yourdomain.com","analyst":"analyst@yourdomain.com"}
APP_BASE_URL=https://portal.yourdomain.com

# --- Scheduled weekly digest (Monday 08:00 server local time by default) ---
FAMILY_OFFICE_DIGEST_CRON=1
DIGEST_CRON_DOW=1
DIGEST_CRON_HOUR=8

# --- Security (production) ---
# Comma-separated browser origins allowed to call the API (e.g. https://portal.yourdomain.com)
# FAMILY_OFFICE_CORS_ORIGINS=https://portal.yourdomain.com
# Set to 1 to issue httpOnly session cookies (pair with VITE_SESSION_COOKIE=1 on client build)
# FAMILY_OFFICE_SESSION_COOKIE=1

# --- Optional ---
# FAMILY_OFFICE_VAULT_DIR=
# MASTER_XLSX_PATH=
# FX_NGN_PER_USD=1600
